<script>
var prog=document.getElementById('prog');
window.addEventListener('scroll',function(){
  var s=document.documentElement.scrollTop,h=document.documentElement.scrollHeight-window.innerHeight;
  prog.style.width=(s/h*100)+'%';
});
var obs=new IntersectionObserver(function(e){e.forEach(function(x){if(x.isIntersecting)x.target.classList.add('in');});},{threshold:.09});
document.querySelectorAll('.reveal').forEach(function(el){obs.observe(el);});
function tBC(i){
  var b=document.getElementById('bv'+i),c=document.getElementById('bc'+i),op=b.classList.contains('open');
  document.querySelectorAll('.bc-body').forEach(function(x){x.classList.remove('open');});
  document.querySelectorAll('.bc').forEach(function(x){x.classList.remove('open');});
  if(!op){b.classList.add('open');c.classList.add('open');}
}
var fs={s:true,b:false,d:true,r:false,a:true};
function tf(el,t){
  el.classList.toggle('on');el.classList.toggle('off');fs[t]=!fs[t];
  var sb=fs.s||!fs.b,bb=fs.b||!fs.s;
  document.getElementById('fc0').className='fdc'+(sb?'':' hide');
  document.getElementById('fc1').className='fdc'+(sb?'':' hide');
  document.getElementById('fc2').className='fdc'+(bb?'':' hide');
  var v=document.querySelectorAll('.fdc:not(.hide)').length;
  document.getElementById('fdc').textContent=v+' modelo'+(v!==1?'s':'');
}
function tEl(i){
  var b=document.getElementById('el'+i),el=document.querySelectorAll('.el')[i],op=b.classList.contains('open');
  document.querySelectorAll('.el-body').forEach(function(x){x.classList.remove('open');});
  document.querySelectorAll('.el').forEach(function(x){x.classList.remove('open');});
  if(!op){b.classList.add('open');el.classList.add('open');}
}
function sTL(i){
  document.querySelectorAll('.tli').forEach(function(x){x.classList.remove('act');});
  document.querySelectorAll('.tli')[i].classList.add('act');
}
window.addEventListener('load',function(){
  setTimeout(function(){
    document.querySelectorAll('.hero .reveal').forEach(function(el,i){setTimeout(function(){el.classList.add('in');},i*120);});
  },100);
});
</script>
</body>
